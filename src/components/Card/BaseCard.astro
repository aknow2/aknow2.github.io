---
const { title, description, imageUrl, imageAlt, imageWebpUrl, links } = Astro.props;
const safeLinks = Array.isArray(links) ? links : [];
---

<div class="card">
	<picture class="card__media">
		{imageWebpUrl ? <source srcset={imageWebpUrl} type="image/webp" /> : null}
		<img
			class="card__bg"
			src={imageUrl}
			alt={imageAlt}
			loading="lazy"
			decoding="async"
			fetchpriority="high"
		/>
	</picture>
	<div class="card__overlay">
		<div class="card__text">
			<div class="card__copy">
				<h3 class="card__title">{title}</h3>
				<p class="card__description">{description}</p>
			</div>
			{safeLinks.length > 0 ? (
				<div class="card__links">
					{safeLinks.map((link) => (
						<a
							class="card__link"
							href={link.url}
							target="_blank"
							rel="noopener noreferrer"
							aria-label={link.label}
							title={link.label}
						>
							{link.iconUrl ? (
								<img src={link.iconUrl} alt="" aria-hidden="true" />
							) : (
								<span class="card__link-label">{link.label}</span>
							)}
						</a>
					))}
				</div>
			) : null}
		</div>
	</div>
</div>

<style>
	.card {
		position: relative;
		overflow: hidden;
		display: flex;
		align-items: stretch;
		border-radius: var(--card-radius);
		background: #f8fafc;
		color: inherit;
		min-height: 160px;
		isolation: isolate;
	}

	.card:hover {
		box-shadow: none;
	}

	.card:focus-within {
		outline: 3px solid rgba(15, 23, 42, 0.65);
		outline-offset: 3px;
	}


	.card__bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(1.15) contrast(1.08);
		transition: filter 0.35s ease;
	}

	.card__media {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		margin: 0;
	}

	.card__overlay {
		position: absolute;
		inset: 0;
		height: 100%;
		z-index: 1;
		display: flex;
		align-items: flex-end;
		background: rgba(255, 255, 255, 0.18);
		border-radius: var(--card-radius);
		backdrop-filter: blur(2px);
		-webkit-backdrop-filter: blur(2px);
		transition: backdrop-filter 0.25s ease, background 0.25s ease;
	}

	.card:has(.card__link:hover) .card__overlay,
	.card:has(.card__link:focus-visible) .card__overlay,
	.card:has(.card__link:active) .card__overlay {
		backdrop-filter: blur(0px);
		-webkit-backdrop-filter: blur(0px);
		background: rgba(0, 0, 0, 0.05);
	}

	.card__text {
		padding: 10px 10px;
		width: 100%;
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: 100%;
	}

	.card__copy {
		display: flex;
		flex-direction: column;
		gap: 4px;
		color: #f8fafc;
		border-radius: 12px;
		padding: 8px 10px;
		text-shadow: 0 2px 8px rgba(15, 23, 42, 0.75);
	}

	.card__links {
		display: flex;
		flex-wrap: wrap;
		gap: 4px;
		margin-top: 12px;
	}

	.card__link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 48px;
		height: 48px;
		border-radius: 999px;
		background: rgba(15, 23, 42, 0.72);
		color: #f8fafc;
		text-decoration: none;
	}

	.card__link img {
		width: 24px;
		height: 24px;
		filter: grayscale(1) contrast(1.05);
	}

	.card__link-label {
		font-size: 0.7rem;
		font-weight: 600;
		padding: 0 6px;
	}

	.card__title {
		margin: 0;
		font-size: 1.1rem;
		line-height: 1;
	}

	.card__description {
		margin: 0;
		color: inherit;
		font-size: 0.95rem;
		line-height: 1.2;
	}

	@media (max-width: 520px) {
		.card {
			min-height: 220px;
		}
	}

	@supports not (backdrop-filter: blur(10px)) {
		.card__overlay {
			background: rgba(255, 255, 255, 0.24);
		}
	}
</style>
